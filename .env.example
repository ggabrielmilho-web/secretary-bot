# ============================================================
# Secretário IA — SaaS — Variáveis de Ambiente
# Copie para .env e preencha com seus dados reais
# ============================================================

# Telegram
TELEGRAM_BOT_TOKEN=token_do_botfather

# OpenAI
OPENAI_API_KEY=sk-proj-...

# Banco de dados
# Dentro do Docker Swarm use o nome do serviço "db" como host
DATABASE_URL=postgresql+asyncpg://postgres:senha_segura@db:5432/secretary_bot_saas

# Timezone
TIMEZONE=America/Sao_Paulo

# ── Google OAuth2 ────────────────────────────────────────────
# Configure em: console.cloud.google.com > APIs > Credenciais
# Tipo: "Aplicativo da Web" — adicione o Redirect URI abaixo
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx
# URL pública que o Google chamará após autorização do usuário
GOOGLE_REDIRECT_URI=https://seudominio.com/oauth/callback

# ── Mercado Pago ─────────────────────────────────────────────
# Obtenha em: mercadopago.com.br > Suas integrações
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxx
# Opcional: segredo HMAC para validar assinatura do webhook
MERCADOPAGO_WEBHOOK_SECRET=

# ── Webhook Server ───────────────────────────────────────────
# URL pública do servidor (usada no notification_url do PIX)
WEBHOOK_PUBLIC_URL=https://seudominio.com
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080

# ── Docker / PostgreSQL ──────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=senha_segura

# ── Plano e Trial ────────────────────────────────────────────
TRIAL_DURATION_DAYS=7
PLAN_PRICE=49.90
